# ==============================================================================
# Continuum Core Infrastructure Configurations
# ==============================================================================

# Relational Database Connection (Switch to our cloud URI for production deployment)
DATABASE_URL="postgres://postgres:postgres@localhost:5432/continuum?sslmode=disable"

# Server Execution Matrix
PORT=8080
ENV=development

# Security Guard Rules
# This will be set to "false" in our staging/production environments to permanently lock down and disable the /api/vaults/:id/warp testing backdoor route.
ALLOW_DEV_TIME_WARP=true

# Lightning Network Daemon (LND) Node Authentication
# Points to local regtest container exposed gRPC interface
LND_HOST="localhost:10009"
LND_MACAROON_PATH="/workspaces/Continuum/infrastructure/docker/lnd_data/data/chain/bitcoin/regtest/admin.macaroon"
LND_TLS_CERT_PATH="/workspaces/Continuum/infrastructure/docker/lnd_data/tls.cert"

# ⚛️ Next.js Public Routing Interface Interceptor 
# Required so client-side fetchers know where to pipe asymmetric packets
NEXT_PUBLIC_API_URL="http://localhost:8080/api"